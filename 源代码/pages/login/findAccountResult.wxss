.certify-checkbox .uni-radio-input {
    border-radius: 50%!important;
    height: 32rpx!important;
    margin-right: 10rpx!important;
    width: 32rpx!important
}

.user-info-item-label {
    color: #666;
    font-size: 28rpx
}

.user-info-item-value {
    color: #444;
    font-size: 28rpx;
    font-weight: 400
}

.certify-page {
    background: #fff;
    box-sizing: border-box;
    height: 100%;
    position: relative
}

.certify-page .certify-bg {
    height: 40rpx;
    width: 100%
}

.certify-page .certify-page {
    -webkit-align-items: center;
    align-items: center;
    background: #fff;
    border-radius: 32rpx 32rpx 8rpx 8rpx;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    padding: 0 28rpx 40rpx;
    -webkit-transform: translateY(-16rpx);
    transform: translateY(-16rpx)
}

.certify-page .certify-body .certify-text {
    color: #aeaeae;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 24rpx;
    margin-bottom: 40rpx;
    margin-left: 20rpx;
    margin-top: 20rpx;
    text-align: center;
    width: 100%
}

.certify-page .certify-body .certify-phone {
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 36rpx;
    margin-top: 50rpx;
    text-align: center;
    width: 100%
}

.certify-page .certify-body .primary-btn {
    background: #ff7272;
    border-radius: 44rpx;
    box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(253,115,89,.4);
    color: #fff;
    width: 300rpx
}

.certify-page .certify-body .can-commit {
    opacity: 1
}
