.certify-checkbox .uni-radio-input {
    border-radius: 50%!important;
    height: 32rpx!important;
    margin-right: 10rpx!important;
    width: 32rpx!important
}

.user-info-item-label {
    color: #666;
    font-size: 28rpx
}

.user-info-item-value {
    color: #444;
    font-size: 28rpx;
    font-weight: 400
}

.certify-page {
    background: #fff;
    box-sizing: border-box;
    height: 100%;
    position: relative
}

.certify-page .certify-bg {
    height: 40rpx;
    width: 100%
}

.certify-page .certify-page {
    -webkit-align-items: center;
    align-items: center;
    background: #fff;
    border-radius: 32rpx 32rpx 8rpx 8rpx;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    padding: 0 28rpx 40rpx;
    -webkit-transform: translateY(-16rpx);
    transform: translateY(-16rpx)
}

.certify-page .certify-body .certify-text {
    color: #aeaeae;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 24rpx;
    margin-left: 20rpx;
    margin-top: 20rpx;
    text-align: left;
    width: 100%
}

.certify-page .certify-body .certify-form {
    box-sizing: border-box;
    position: relative;
    width: 100%
}

.certify-page .certify-body .certify-form .certify-form-item {
    margin: 32rpx 0 24rpx
}

.certify-page .certify-body .certify-form .certify-form-label {
    color: #333;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 28rpx;
    font-weight: 400;
    margin-bottom: 24rpx;
    margin-left: 12rpx
}

.certify-page .certify-body .certify-form .certify-checkbox {
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 22rpx;
    font-weight: 400
}

.certify-page .certify-body .certify-form .certify-checkbox .argument-tip {
    color: #aeaeae
}

.certify-page .certify-body .certify-form .picker-show {
    border-bottom: none;
    border-radius: 52rpx 52rpx 0 0!important
}

.certify-page .certify-body .certify-form .certify-type-picker {
    background: #fff;
    border: 2rpx solid #eee;
    border-radius: 52rpx;
    color: #333;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-weight: 400;
    line-height: 100rpx;
    min-height: 100rpx;
    padding: 0 30rpx;
    position: relative
}

.certify-page .certify-body .certify-form .certify-type-picker .picker-page {
    background: #fff;
    border: 2rpx solid #eee;
    border-radius: 0 0 52rpx 52rpx;
    border-top: none;
    left: -2rpx;
    padding: 0 32rpx;
    position: absolute;
    right: -2rpx;
    z-index: 100
}

.certify-page .certify-body .certify-form .certify-type-picker .picker-current {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: space-between;
    justify-content: space-between
}

.certify-page .certify-body .certify-form .certify-type-picker .picker-hidden-cur::after {
    border-left: 10rpx solid transparent;
    border-right: 10rpx solid transparent;
    border-top: 10rpx solid #000;
    content: "";
    height: 0;
    width: 0
}

.certify-page .certify-body .certify-form .certify-type-picker .picker-show-cur::after {
    border-bottom: 10rpx solid #000;
    border-left: 10rpx solid transparent;
    border-right: 10rpx solid transparent;
    content: "";
    height: 0;
    width: 0
}

.certify-page .certify-body .certify-form .primary-btn {
    background: #ff7272;
    border-radius: 44rpx;
    box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(253,115,89,.4);
    color: #fff
}

.certify-page .certify-body .certify-form .can-commit {
    opacity: 1
}

.certify-page .certify-body .certify-form .no-can-commit {
    opacity: .5
}

.certify-page .certify-body .certify-form .uni-input {
    background: #fff;
    border: 2rpx solid #eee;
    border-radius: 50rpx;
    color: #333;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-weight: 400;
    height: 100rpx;
    padding-left: 30rpx
}

.certify-page .certify-body .certify-form .uni-input::-moz-placeholder {
    color: #bbb;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 28rpx;
    font-weight: 400
}

.certify-page .certify-body .certify-form .uni-input::-webkit-input-placeholder {
    color: #bbb;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 28rpx;
    font-weight: 400
}

.certify-page .certify-body .certify-form .uni-input::placeholder {
    color: #bbb;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 28rpx;
    font-weight: 400
}
