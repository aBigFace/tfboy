.pay-time {
    margin-bottom: 4rpx
}

.footer-container {
    margin-top: 72rpx
}

.order-result {
    background-color: #fff;
    box-sizing: border-box;
    min-height: 100vh;
    padding: 100rpx 28rpx
}

.order-result .result-icon {
    text-align: center
}

.order-result .result-icon wx-image {
    height: 200rpx;
    width: 244rpx
}

.order-result .money {
    font-size: 44rpx
}

.order-result .operate-btn {
    color: #fd6262;
    margin-top: 100rpx
}

.order-result .operate-btn wx-button {
    border: 2rpx solid #ff7272;
    color: #fd6262;
    font-size: 28rpx;
    height: 80rpx;
    line-height: 80rpx;
    width: 240rpx
}

.next-tip {
    color: #999;
    font-size: 26rpx;
    margin-top: 16rpx
}
