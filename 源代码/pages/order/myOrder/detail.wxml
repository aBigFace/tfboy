<view class="page order-detail-page" style="{{'overflow:'+aB+';'+'max-height:'+aC}}">
    <view class="header-bg base-container">
        <view class="order-status flex-center">
            <view class="status-text">{{a}}</view>
        </view>
        <view class="order-desc text-light">
            <view class="flex-center text-ashy" wx:if="{{b}}">剩余时间<uni-countdown bind:__l="__l" uI="3a666044-0" uP="{{d}}" wx:if="{{c}}"></uni-countdown>
            </view>
            <text wx:elif="{{e}}">请耐心等待商家发货</text>
            <text wx:elif="{{f}}">订单退款成功！</text>
            <text wx:elif="{{g}}">欢迎再次购买！</text>
            <text wx:elif="{{h}}">您的包裹正快马加鞭的赶来</text>
            <text wx:elif="{{i}}">
                <text wx:if="{{j}}">部分商品已发货，请耐心等待其他商品发货</text>
                <text wx:else>部分商品已发货，请耐心等待其他商品发货</text>
            </text>
            <text wx:elif="{{k}}">
                <text wx:if="{{l}}">订单超时未支付取消</text>
                <text wx:else>订单已经取消</text>
            </text>
            <text wx:elif="{{m}}">{{n}}</text>
            <text wx:else>暂无信息</text>
        </view>
    </view>
    <view class="base-container page-content">
        <view class="base-white-radius-container m-t-10 m-b-10" wx:if="{{o}}">
            <view class="p-b-5 p-t-5">
                <view class="font-28 text-primary-grey m-b-5 text-bold">
                    <text class="m-r-15">{{p}}</text>
                    <text>{{q}}</text>
                </view>
                <view class="text-gray-s">{{r}}</view>
            </view>
        </view>
        <view class="order-package" wx:elif="{{s}}">
            <view class="flex-center m-b-10" wx:if="{{t}}">
                <view bindtap="{{product.c}}" class="{{product.b}}" wx:for="{{v}}" wx:for-item="product" wx:key="d">
                    <text>包裹{{product.a}}</text>
                </view>
            </view>
            <view bindtap="{{product.g}}" class="base-white-radius-container m-b-10" wx:if="{{product.a}}" wx:for="{{w}}" wx:for-item="product" wx:key="h">
                <view class="flex-space-between-center" wx:if="{{product.b}}">
                    <view class="text-gray-xs m-r-10">
                        <text class="logistics-company">运单号</text>{{product.c}}</view>
                    <view class="text-gray-xs">
                        <text catchtap="{{product.d}}" class="logistics-copy">复制</text>
                        <text>查看详情</text>
                    </view>
                </view>
                <view class="logistics-content m-t-10">
                    <view class="logistics-status">{{product.e}}</view>
                    <view class="logistics-current max-line-two">{{product.f}}</view>
                </view>
            </view>
        </view>
        <view class="order-products">
            <view>
                <view class="product-goods border-bottom" wx:for="{{x}}" wx:for-item="product" wx:key="c">
                    <order-product-item bind:__l="__l" uI="{{product.a}}" uP="{{product.b}}" wx:if="{{product.b}}"></order-product-item>
                </view>
                <view class="btn-bar text-right">
                    <view class="order-total text-right p-t-15 p-b-20">
                        <text class="text-primary-grey m-r-10 totlePrice">商品总价</text>
                        <view class="text-primary-grey text-bold">{{y}}</view>
                    </view>
                    <view class="order-total text-right p-b-20" wx:if="{{z}}">
                        <text class="text-primary-grey m-r-10 totlePrice">运费</text>
                        <view class="text-primary-grey text-bold">
                            <text class="text-gray" wx:if="{{A}}"> 包邮 </text>
                            <price bind:__l="__l" uI="3a666044-2" uP="{{B||''}}" wx:else></price>
                        </view>
                    </view>
                    <view class="order-total text-right p-b-20" wx:if="{{C}}">
                        <text class="text-primary-grey m-r-10 totlePrice">小葵花实付</text>
                        <view class="surplus-pay-num text-bold">-{{D}}</view>
                    </view>
                    <view class="order-total text-right p-t-15 p-b-5">
                        <view class="text-primary-grey">
                            <text class="text-tip">总计:</text>
                            <view style="{{'display:'+'inline-block'}}">
                                <price bind:__l="__l" class="text-bold font-36 text-red" uI="3a666044-3" uP="{{E}}" wx:if="{{E}}"></price>
                                <text class="text-red font-36" wx:if="{{F}}">积分</text>
                            </view>
                        </view>
                    </view>
                </view>
            </view>
        </view>
        <view class="order-detail-section base-white-radius-container m-t-10">
            <view class="order-detail-section-item flex-space-between-center">
                <text class="text-primary-grey font-28">订单编号</text>
                <view class="flex-1 text-right text-gray font-28 order-copy">
                    <text>{{G}}</text>
                    <text bindtap="{{H}}" class="text-primary new-copy-icon m-l-5">复制</text>
                </view>
            </view>
            <view class="order-detail-section-item flex-space-between-center">
                <text class="text-primary-grey font-28">下单时间</text>
                <view class="flex-1 text-right text-gray font-28">{{I}}</view>
            </view>
            <view class="order-detail-section-item flex-space-between-center" wx:if="{{J}}">
                <text class="text-primary-grey font-28">支付时间</text>
                <view class="flex-1 text-right text-gray font-28">{{K}}</view>
            </view>
            <view class="order-detail-section-item flex-space-between-center" wx:if="{{L}}">
                <text class="text-primary-grey font-28">支付方式</text>
                <view class="flex-1 text-right text-gray font-28">{{M}}</view>
            </view>
        </view>
        <view class="order-detail-section base-white-radius-container m-t-10" wx:if="{{N}}">
            <view class="order-detail-section-item flex-space-between-center">
                <text class="text-primary-grey font-28">收货人</text>
                <view class="flex-1 text-right text-gray font-28">
                    <text>
                        <text class="m-r-15">{{O}}</text>
                        <text>{{P}}</text>
                    </text>
                </view>
            </view>
            <view class="order-detail-section-item flex-space-between-center">
                <text class="text-primary-grey font-28">收货地址</text>
                <view class="flex-1 text-right text-gray m-l-30 font-28">{{Q}}</view>
            </view>
        </view>
        <view class="order-detail-section base-white-radius-container m-t-10" wx:if="{{R}}">
            <view class="order-detail-section-item buyer-remark-item flex-space-between-center">
                <text class="text-primary-grey font-28">订单留言</text>
                <view class="flex-1 text-right text-gray font-28">{{S}}</view>
            </view>
        </view>
        <view class="fixed-bottom-container base-white-container">
            <button bindtap="{{U}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{T}}">申请售后</button>
            <button bindtap="{{W}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{V}}">售后中</button>
            <button bindtap="{{Z}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{X}}">{{Y}}</button>
            <button bindtap="{{ab}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{aa}}">删除订单</button>
            <button bindtap="{{ad}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{ac}}">取消订单</button>
            <button bindtap="{{af}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{ae}}">取消订单</button>
            <button bindtap="{{ah}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{ag}}">提醒发货</button>
            <button bindtap="{{aj}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{ai}}">修改地址</button>
            <button bindtap="{{al}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{ak}}">查看物流</button>
            <button bindtap="{{an}}" class="plain-btn" plain="{{true}}" size="mini" type="primary" wx:if="{{am}}">确认收货</button>
            <button bindtap="{{ap}}" class="primary-btn" disabled="{{aq}}" size="mini" type="primary" wx:if="{{ao}}">立即支付</button>
        </view>
        <cancel-order-confirm bind:__l="__l" bindcancel="{{at}}" bindconfirm="{{as}}" class="r" uI="3a666044-4" uR="cancelConfirmRef"></cancel-order-confirm>
        <confirm-modal bind:__l="__l" class="r" uI="3a666044-5" uR="confirmModalRef"></confirm-modal>
        <confirm-modal-reason bind:__l="__l" bindcancel="{{ay}}" bindconfirm="{{ax}}" class="r" uI="3a666044-6" uR="confirmModalReasonRef"></confirm-modal-reason>
    </view>
    <customer-service bind:__l="__l" uI="3a666044-7"></customer-service>
    <post-age-dialog bind:__l="__l" class="r" uI="3a666044-8" uP="{{aA}}" uR="postAgePopRef" wx:if="{{aA}}"></post-age-dialog>
</view>
