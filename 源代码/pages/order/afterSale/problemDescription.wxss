.problem-description {
    background: #fff;
    border-radius: 12rpx;
    padding: 32rpx 24rpx;
    width: 702rpx
}

.problem-description .desc {
    background: #f8f8f8;
    border-radius: 8rpx;
    color: #666;
    font-size: 26rpx;
    font-weight: 400;
    line-height: 72rpx;
    margin-bottom: 24rpx;
    padding: 0 20rpx;
    width: 614rpx;
    word-break: break-all
}

.problem-description .pic {
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: flex-start;
    justify-content: flex-start
}

.problem-description .pic .upload-item {
    border-radius: 8rpx;
    height: 144rpx;
    margin-right: 16rpx;
    overflow: hidden;
    position: relative;
    width: 144rpx
}

.problem-description .pic .upload-item wx-image {
    height: 144rpx;
    width: 144rpx
}

.problem-description .pic .upload-item .video-bg {
    background-size: cover;
    height: 144rpx;
    width: 144rpx
}

.problem-description .pic .upload-item .play {
    height: 80rpx;
    left: 33rpx;
    position: absolute;
    top: 34rpx;
    width: 80rpx
}

.problem-description .pic .upload-item:last-child {
    margin-right: 0
}
