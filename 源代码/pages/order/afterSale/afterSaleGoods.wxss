.page {
    background: #f5f5f5
}

.page .main-goods {
    background-color: #fff;
    border-radius: 12rpx;
    margin-bottom: 16rpx;
    padding: 24rpx
}

.page .main-goods .shop_list {
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: flex-start;
    justify-content: flex-start
}

.page .main-goods .shop_list wx-image {
    border-radius: 8rpx;
    height: 120rpx;
    width: 120rpx
}

.page .main-goods .shop_list .shop-name {
    display: -webkit-flex;
    display: flex;
    -webkit-flex: 1;
    flex: 1;
    -webkit-flex-direction: column;
    flex-direction: column;
    height: 100%;
    margin-left: 16rpx
}

.page .main-goods .shop_list .shop-name .name {
    color: #222;
    font-size: 26rpx;
    font-weight: 500;
    margin-bottom: 12rpx
}

.page .main-goods .shop_list .shop-name .msg {
    color: #999;
    font-size: 22rpx;
    font-weight: 400;
    margin-bottom: 12rpx
}

.page .main-goods .shop_list .shop-name .msg .left {
    margin-left: 16rpx
}

.page .main-goods .shop_list .shop-name .sale-type {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: flex-start;
    justify-content: flex-start;
    margin-bottom: 16rpx
}

.page .main-goods .shop_list .shop-name .sale-type .sale-desc {
    background: #fff3f3;
    border-radius: 4rpx;
    color: #fd6262;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 20rpx;
    font-weight: 400;
    height: 28rpx;
    margin-right: 8rpx;
    text-align: center;
    width: 64rpx
}

.page .main-goods .shop_list .evaluation-btn {
    -webkit-align-items: center;
    align-items: center;
    -webkit-align-self: center;
    align-self: center;
    display: -webkit-flex;
    display: flex;
    height: 52rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 125rpx
}

.page .primary-btn {
    background: #ff7272;
    border-radius: 44rpx;
    height: 88rpx;
    width: 688rpx
}
