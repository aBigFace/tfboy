.page {
    background: #f5f5f5
}

.search-page .apply-list {
    background-color: #fff;
    border-radius: 12rpx;
    padding: 24rpx
}

.search-page .apply-list .title {
    color: #333;
    font-size: 32rpx;
    font-weight: 500;
    line-height: 48rpx;
    margin-bottom: 16rpx;
    margin-top: 8rpx
}

.search-page .apply-list .item {
    -webkit-align-items: center;
    align-items: center;
    border-bottom: 1rpx solid #eee;
    display: -webkit-flex;
    display: flex;
    height: 136rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    width: 654rpx
}

.search-page .apply-list .item .icon {
    height: 60rpx;
    margin-right: 20rpx;
    width: 60rpx
}

.search-page .apply-list .item .text {
    -webkit-flex: 1;
    flex: 1
}

.search-page .apply-list .item .name {
    color: #333;
    font-size: 32rpx;
    font-weight: 500;
    height: 32rpx;
    line-height: 48rpx;
    margin-bottom: 12rpx
}

.search-page .apply-list .item .desc {
    color: #999;
    font-size: 24rpx;
    font-weight: 400;
    height: 24rpx;
    line-height: 36rpx
}

.search-page .apply-list .item:last-child {
    border: none
}
