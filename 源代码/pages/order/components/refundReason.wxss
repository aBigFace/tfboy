.cancel-order-modal {
    background-color: #fff;
    border-top-left-radius: 24rpx;
    border-top-right-radius: 24rpx
}

.cancel-order-modal .modal-content,.cancel-order-modal .modal-header {
    padding: 28rpx 28rpx 0
}

.cancel-order-modal .cancel-tips {
    font-size: 26rpx;
    margin-bottom: 20rpx
}

.cancel-order-modal .cancel-reason-list {
    height: 500rpx;
    overflow-y: auto
}

.cancel-order-modal .cancel-reason-list .reason-item {
    -webkit-align-items: center;
    align-items: center;
    background: #f5f5f5;
    border: 2rpx solid #f5f5f5;
    border-radius: 12rpx;
    display: -webkit-flex;
    display: flex;
    height: 56rpx;
    margin-bottom: 16rpx
}

.cancel-order-modal .cancel-reason-list .reason-item .reason {
    color: #333;
    font-size: 30rpx;
    font-weight: 400
}

.cancel-order-modal .cancel-reason-list .active {
    border: 2px solid #ff7272
}

.cancel-order-modal .cancel-reason-list .active .reason {
    color: #ff7272
}
