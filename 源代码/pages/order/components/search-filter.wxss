.search-filter-modal {
    background-color: #fff;
    border-bottom-left-radius: 24rpx;
    border-bottom-right-radius: 24rpx
}

.search-filter-modal .modal-content,.search-filter-modal .modal-header {
    padding: 28rpx 28rpx 0
}

.search-filter-modal .modal-content .filter-title,.search-filter-modal .modal-header .filter-title {
    margin: 40rpx 0
}

.search-filter-modal .list {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-wrap: wrap;
    flex-wrap: wrap;
    -webkit-justify-content: space-between;
    justify-content: space-between
}

.search-filter-modal .list .item {
    background: #f5f5f5;
    border-radius: 8rpx;
    border-radius: 36rpx;
    box-sizing: border-box;
    color: #666;
    line-height: 72rpx;
    margin-bottom: 24rpx;
    min-height: 72rpx;
    text-align: center;
    width: 336rpx
}

.search-filter-modal .list .item.active {
    background: #ffeaea;
    border: 1px solid #e85252;
    box-sizing: border-box;
    color: #e85252
}

.search-filter-modal .modal-footer {
    border-radius: 0 0 24rpx 24rpx;
    box-shadow: 0 2rpx 8rpx 0 rgba(0,0,0,.04);
    font-size: 30rpx
}

.search-filter-modal .modal-footer wx-button {
    border-radius: 44rpx;
    height: 88rpx;
    margin-bottom: 24rpx;
    width: 50%
}

.search-filter-modal .modal-footer .reset-btn {
    border: 1rpx solid #ddd;
    color: #333
}
