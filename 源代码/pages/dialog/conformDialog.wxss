.confirm-modal {
    background-color: #fff;
    border-radius: 45rpx;
    box-sizing: border-box;
    width: 600rpx
}

.confirm-modal .dialog-header {
    font-weight: 500
}

.confirm-modal .dialog-header .dialog-description {
    background: url("https://cos.tfent.cn/xgg-file-folder/tf-app/wechat/static/image/mine/dialog-bg@2x.png") no-repeat;
    background-size: 100% 100%;
    color: #fff;
    font-family: SourceHanSansCN-Medium,SourceHanSansCN;
    text-align: center
}

.confirm-modal .dialog-header .dialog-description .header-info {
    font-size: 28rpx;
    font-weight: 500;
    padding: 28rpx 0 12rpx
}

.confirm-modal .dialog-header .dialog-description .tip-box {
    padding-bottom: 26rpx
}

.confirm-modal .dialog-header .dialog-description .tip-box .header-tip {
    font-size: 22rpx;
    font-weight: 500
}

.confirm-modal .confirm-dialog-content {
    font-size: 30rpx;
    text-align: center
}

.confirm-modal .dialog-content {
    background: #f5f5f5;
    border-radius: 8rpx;
    border-top: none;
    margin: 48rpx 28rpx 0;
    padding: 38rpx 0
}

.confirm-modal .dialog-content .name-phone {
    color: #333;
    font-size: 32rpx;
    font-weight: 500;
    margin: 0 28rpx
}

.confirm-modal .dialog-content .name-phone .name-tip {
    margin-right: 16rpx
}

.confirm-modal .dialog-content .address-tip {
    color: #8b8b8b;
    font-size: 24rpx;
    line-height: 36rpx;
    margin: 20rpx 28rpx 0
}

.confirm-modal .dialog-content .dialog-image {
    height: 320rpx;
    margin: 40rpx auto;
    width: 400rpx
}

.confirm-modal .activeContent {
    background: #fff3f3;
    border: 2rpx solid #ff7272
}

.confirm-modal .dialog-footer {
    display: -webkit-flex;
    display: flex;
    padding: 56rpx 0 64rpx
}

.confirm-modal .dialog-footer wx-button {
    border: 2rpx solid #ddd;
    border-radius: 44rpx;
    color: #333;
    font-size: 30rpx;
    font-weight: 400;
    height: 88rpx;
    max-width: 280rpx;
    min-width: 220rpx
}

.confirm-modal .dialog-footer .confirm-btn {
    background: #ff7272;
    color: #fff
}
