.tabList {
    -webkit-align-items: center;
    align-items: center;
    background: #fff;
    display: -webkit-flex;
    display: flex;
    height: 100rpx;
    -webkit-justify-content: space-evenly;
    justify-content: space-evenly
}

.tabList .tab-item {
    color: #888;
    font-size: 28rpx;
    height: 50rpx;
    position: relative
}

.tabList .tab-item .active {
    border-bottom: 8rpx solid #e85252;
    border-radius: 2rpx 2rpx 2rpx 2rpx;
    color: #333;
    font-weight: 500;
    padding-bottom: 30rpx
}

.acquire-box .item {
    -webkit-align-items: center;
    align-items: center;
    background: #fff;
    border-radius: 12rpx;
    display: -webkit-flex;
    display: flex;
    height: 120rpx;
    -webkit-justify-content: flex-start;
    justify-content: flex-start;
    margin-bottom: 12rpx;
    width: 702rpx
}

.acquire-box .item .left {
    -webkit-flex: 1;
    flex: 1;
    margin-left: 24rpx
}

.acquire-box .item .left .title {
    color: #222;
    font-size: 26rpx;
    font-weight: 400;
    margin-bottom: 12rpx
}

.acquire-box .item .left .shop-bottom {
    margin-bottom: 12rpx
}

.acquire-box .item .left .date {
    color: #999;
    font-size: 22rpx;
    font-weight: 400
}

.acquire-box .item .left .order {
    -webkit-align-items: center;
    align-items: center;
    color: #666;
    display: -webkit-flex;
    display: flex;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 24rpx;
    font-weight: 400;
    margin-bottom: 14rpx;
    margin-top: 18rpx
}

.acquire-box .item .left .order wx-image {
    height: 28rpx;
    margin-left: 10rpx;
    width: 28rpx
}

.acquire-box .item .right {
    color: #333;
    font-size: 32rpx;
    font-weight: 500;
    margin-right: 24rpx
}

.acquire-box .shop-height {
    height: 160rpx
}
