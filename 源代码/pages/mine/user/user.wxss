.user-info-page {
    position: relative
}

.user-info-page .user-info-item-label {
    color: #666;
    font-size: 28rpx;
    font-weight: 400
}

.user-info-page .icon-copy {
    height: 32rpx;
    margin-left: 10rpx;
    width: 32rpx
}

.user-info-page .item-center {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: flex-end;
    justify-content: flex-end
}

.user-info-page .user-info-item-value {
    color: #999;
    font-size: 28rpx;
    font-weight: 400
}

.user-info-page .avatar-info {
    -webkit-align-items: center;
    align-items: center;
    border-bottom: 1rpx solid #eee;
    height: 90rpx;
    padding: 0 10rpx;
    position: relative
}

.user-info-page .avatar-info .avatar-label {
    width: 100rpx
}

.user-info-page .avatar-info .avatar-wrapper {
    background-color: #fff;
    -webkit-flex: 1;
    flex: 1;
    height: 100%
}

.user-info-page .avatar-info .avatar-wrapper .imgStyle {
    border-radius: 50%;
    height: 72rpx;
    position: absolute;
    right: 20rpx;
    top: 10rpx;
    width: 72rpx;
    z-index: 999!important
}

.user-info-page .mask {
    background-color: #fff;
    height: 90rpx;
    left: 128rpx;
    position: absolute;
    top: 20rpx;
    width: 600rpx;
    z-index: 100
}

.user-info-page .user-info-box {
    background: #fff;
    border-radius: 8rpx;
    box-sizing: border-box;
    margin-bottom: 20rpx;
    padding-left: 24rpx;
    padding-right: 24rpx
}

.user-info-page .user-info-item {
    -webkit-align-items: center;
    align-items: center;
    border-bottom: 1rpx solid #eee;
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    line-height: 1.5;
    padding: 26rpx 10rpx
}

.user-info-page .user-info-item.avatar-item {
    padding-bottom: 0;
    padding-top: 0
}

.user-info-page .user-info-item:last-child {
    border: none
}

.user-info-page .user-info-item .no-certify {
    color: #bbb;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 28rpx;
    font-weight: 400
}

.user-info-page .user-info-item .has-certify {
    background: linear-gradient(135deg,#e6be7d,#c08243);
    border-radius: 4rpx;
    color: #fff;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 22rpx;
    font-weight: 400;
    height: 36rpx;
    padding: 6rpx 8rpx
}

.user-info-page .user-info-item .user-info-item-value {
    -webkit-flex: 1;
    flex: 1;
    text-align: right
}

.user-info-page .user-info-item .order-item-icon-other {
    height: 32rpx;
    margin-left: 20rpx;
    margin-top: 6rpx;
    vertical-align: middle;
    width: 32rpx
}

.user-info-page .user-info-item .order-item-icon-red {
    height: 16rpx;
    margin-left: 20rpx;
    margin-top: 12rpx;
    vertical-align: middle;
    width: 16rpx
}
