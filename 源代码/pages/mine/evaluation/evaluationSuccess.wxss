.page {
    background: #f5f5f5
}

.page .evaluation-success {
    background: #fff;
    height: 100vh;
    margin-bottom: 16rpx;
    width: 750rpx
}

.page .evaluation-success-header {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    height: 160rpx;
    -webkit-justify-content: center;
    justify-content: center
}

.page .evaluation-success-header wx-image {
    height: 64rpx;
    margin-right: 16rpx;
    width: 64rpx
}

.page .evaluation-success-header wx-text {
    color: #333;
    font-size: 32rpx;
    font-weight: 500
}

.page .evaluation-success-btn,.page .evaluation-success-btn .back {
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: center;
    justify-content: center
}

.page .evaluation-success-btn .back {
    -webkit-align-items: center;
    align-items: center;
    border: 2rpx solid #ff7272;
    border-radius: 40rpx;
    color: #ff7272;
    font-size: 28rpx;
    font-weight: 400;
    height: 80rpx;
    width: 240rpx
}

.page .evaluation-success-btn .continue {
    margin-left: 48rpx
}

.page .main-goods {
    background-color: #fff;
    border-radius: 12rpx;
    margin-bottom: 16rpx;
    padding-bottom: 20rpx
}

.page .main-goods .title {
    color: #333;
    font-size: 28rpx;
    font-weight: 400;
    margin: 0 0 28rpx 24rpx;
    padding-top: 32rpx
}

.page .main-goods .shop_list {
    background: #f5f5f5;
    border-radius: 12rpx;
    display: -webkit-flex;
    display: flex;
    height: 128rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    margin: 24rpx;
    padding: 24rpx
}

.page .main-goods .shop_list wx-image {
    height: 120rpx;
    width: 120rpx
}

.page .main-goods .shop_list .shop-name {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    height: 100%;
    margin-left: 16rpx;
    width: 560rpx
}

.page .main-goods .shop_list .shop-name .name {
    color: #222;
    font-size: 26rpx;
    font-weight: 500;
    line-height: 40rpx
}

.page .main-goods .shop_list .shop-name .msg {
    color: #999;
    font-size: 22rpx;
    font-weight: 400;
    line-height: 34rpx
}

.page .main-goods .shop_list .shop-name .msg .left {
    margin-left: 16rpx
}

.page .main-goods .shop_list .evaluation-btn {
    -webkit-align-items: center;
    align-items: center;
    -webkit-align-self: flex-end;
    align-self: flex-end;
    background: #ff7272;
    border-radius: 32rpx;
    box-shadow: 0 4rpx 12rpx 0 rgba(255,90,113,.44);
    color: #fff;
    display: -webkit-flex;
    display: flex;
    font-size: 26rpx;
    font-weight: 400;
    height: 52rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 128rpx
}
