.page {
    background: #f5f5f5
}

.page .evaluation-detail {
    background: #fff;
    padding: 30rpx 24rpx 24rpx
}

.page .evaluation-detail-header {
    -webkit-justify-content: space-between;
    justify-content: space-between
}

.page .evaluation-detail-header,.page .evaluation-detail-header .left {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex
}

.page .evaluation-detail-header .left wx-image {
    border-radius: 50%;
    height: 60rpx;
    width: 60rpx
}

.page .evaluation-detail-header .left wx-text {
    color: #222;
    font-size: 26rpx;
    font-weight: 400;
    margin-left: 8rpx
}

.page .evaluation-detail-header .right {
    color: #999;
    font-size: 24rpx;
    font-weight: 400
}

.page .evaluation-detail-score wx-image {
    height: 24rpx;
    margin-right: 6rpx;
    width: 24rpx
}

.page .evaluation-detail-content {
    word-wrap: break-word;
    color: #333;
    font-size: 26rpx;
    margin-bottom: 30rpx
}

.page .evaluation-detail-pic {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-wrap: wrap;
    flex-wrap: wrap;
    -webkit-justify-content: flex-start;
    justify-content: flex-start
}

.page .evaluation-detail-pic .item {
    height: 212rpx;
    margin-bottom: 10rpx;
    margin-right: 10rpx;
    position: relative;
    width: 212rpx
}

.page .evaluation-detail-pic .item .play {
    height: 80rpx;
    left: 66rpx;
    position: absolute;
    top: 66rpx;
    width: 80rpx
}

.page .evaluation-detail-pic .video-bg {
    background: url("https://cos.tfent.cn/xgg-file-folder/tf-app/cover/video-bg.png") no-repeat;
    background-size: cover;
    height: 212rpx;
    width: 212rpx
}

.page .evaluation-detail-pic wx-image {
    height: 212rpx;
    width: 212rpx
}

.page .evaluation-detail-pic wx-video {
    height: 212rpx;
    -o-object-fit: fill;
    object-fit: fill;
    width: 212rpx
}

.page .evaluation-detail-pic .item:nth-child(3n) {
    margin-right: 0rpx
}

.page .evaluation-detail-reply {
    background: #f5f5f5;
    border-radius: 8rpx;
    color: #666;
    font-size: 24rpx;
    font-weight: 400;
    padding: 20rpx 30rpx 20rpx 24rpx;
    width: 600rpx
}

.page .evaluation-detail-sku-box {
    -webkit-align-items: flex-start;
    align-items: flex-start;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column
}

.page .evaluation-detail-sku {
    background: #f2f2f2;
    border-radius: 4rpx;
    color: #999;
    font-size: 22rpx;
    font-weight: 400;
    height: 40rpx;
    margin-top: 12rpx;
    padding: 0 10rpx
}
