.page {
    background: #f5f5f5
}

.page .main-goods {
    background-color: #fff;
    border-radius: 12rpx;
    padding: 24rpx
}

.page .main-goods .shop_list {
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    margin-bottom: 44rpx
}

.page .main-goods .shop_list wx-image {
    height: 120rpx;
    width: 120rpx
}

.page .main-goods .shop_list .shop-name {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    height: 100%;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    margin-left: 16rpx;
    width: 560rpx
}

.page .main-goods .shop_list .shop-name .name {
    color: #222;
    font-size: 26rpx;
    font-weight: 500;
    line-height: 40rpx
}

.page .main-goods .shop_list .shop-name .msg {
    color: #999;
    font-size: 22rpx;
    font-weight: 400;
    line-height: 34rpx
}

.page .main-goods .shop_list .shop-name .msg .left {
    margin-left: 16rpx
}

.page .main-goods .shop_list .shop-name .msg .price {
    color: #333;
    font-size: 28rpx;
    font-weight: 500;
    line-height: 42rpx
}

.page .main-goods .shop_list .evaluation-btn {
    -webkit-align-items: center;
    align-items: center;
    -webkit-align-self: flex-end;
    align-self: flex-end;
    background: #ff7272;
    border-radius: 32rpx;
    box-shadow: 0 4rpx 12rpx 0 rgba(255,90,113,.44);
    color: #fff;
    display: -webkit-flex;
    display: flex;
    font-size: 26rpx;
    font-weight: 400;
    height: 52rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 128rpx
}

.page .main-goods .shop_list .review {
    background: #fff;
    border: 2rpx solid #ddd;
    border-radius: 32rpx;
    box-shadow: none;
    color: #333;
    font-size: 24rpx;
    font-weight: 400
}

.page .main-goods .title {
    color: #333;
    font-size: 28rpx;
    font-weight: 500
}

.page .main-goods .evaluate-box {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    margin-bottom: 40rpx
}

.page .main-goods .evaluate-box wx-image {
    height: 56rpx;
    width: 56rpx
}

.page .main-goods .evaluate-box .text {
    color: #ff7272;
    font-size: 26rpx
}

.page .main-goods .desc {
    height: 176rpx;
    position: relative
}

.page .main-goods .desc wx-textarea {
    width: 100%
}

.page .main-goods .desc .textarea-view,.page .main-goods .desc wx-textarea {
    background: #f8f8f8;
    border-radius: 8rpx;
    box-sizing: border-box;
    color: #bbb;
    font-size: 28rpx;
    height: 128rpx;
    padding: 24rpx 20rpx;
    resize: none
}

.page .main-goods .desc .textarea-view {
    overflow-y: auto;
    width: 724rpx;
    width: 100%;
    word-break: break-all
}

.page .main-goods .desc .box-input-bottom-ran {
    bottom: 2rpx;
    color: #c5c5c5;
    font-size: 22rpx;
    font-weight: 400;
    position: absolute;
    right: 5rpx
}

.page .main-goods .desc ::-webkit-input-placeholder {
    font-size: 22rpx;
    padding-left: 2rpx
}

.page .main-goods .box-upload {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-wrap: wrap;
    flex-wrap: wrap;
    -webkit-justify-content: flex-start;
    justify-content: flex-start;
    padding-top: 24rpx
}

.page .main-goods .box-upload .upload-item {
    background: #f5f5f5;
    border-radius: 8rpx;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    height: 212rpx;
    -webkit-justify-content: center;
    justify-content: center;
    margin-bottom: 10rpx;
    margin-right: 10rpx;
    position: relative;
    width: 212rpx
}

.page .main-goods .box-upload .upload-item .close-img {
    height: 38rpx;
    position: absolute;
    right: 0rpx;
    top: 0rpx;
    width: 38rpx;
    z-index: 1
}

.page .main-goods .box-upload .upload-item .close-img wx-image {
    height: 36rpx;
    width: 36rpx
}

.page .main-goods .box-upload .upload-item .video-bg {
    background: url("https://cos.tfent.cn/xgg-file-folder/tf-app/cover/video-bg.png") no-repeat;
    background-size: cover;
    height: 212rpx;
    width: 212rpx
}

.page .main-goods .box-upload .upload-item .video-bg .play {
    height: 80rpx;
    left: 66rpx;
    position: absolute;
    top: 66rpx;
    width: 80rpx
}

.page .main-goods .box-upload .upload-item .image {
    height: 56rpx;
    margin: 0 auto;
    width: 56rpx
}

.page .main-goods .box-upload .upload-item .imageUpload {
    border-radius: 8rpx;
    height: 100%;
    width: 100%
}

.page .main-goods .box-upload .upload-item .close {
    border-radius: 50%;
    height: 30rpx;
    position: absolute;
    right: 5rpx;
    top: 5rpx;
    width: 30rpx;
    z-index: 20
}

.page .main-goods .box-upload .upload-item .upload-text {
    color: #999;
    font-size: 24rpx;
    font-weight: 400;
    letter-spacing: 0;
    padding-top: 8rpx;
    text-align: center
}

.page .main-goods .box-upload .upload-item:nth-of-type(2n) {
    margin-right: 8rpx
}

.page .main-goods .box-upload .upload-item:nth-of-type(3n) {
    margin-right: 0
}

.page .primary-btn {
    border-radius: 44rpx;
    margin-top: 262rpx
}
