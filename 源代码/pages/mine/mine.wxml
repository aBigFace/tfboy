<view class="page mine-page">
    <view class="mine-head">
        <view bindtap="{{t}}" class="user-info flex" wx:if="{{a}}">
            <view class="img-box">
                <image class="avatar" src="{{c}}" wx:if="{{b}}"></image>
                <image class="avatar" src="{{d}}" wx:else></image>
            </view>
            <view wx:if="{{e}}">
                <view class="user-detail">
                    <view class="nickname">{{f}}</view>
                    <view class="{{[m,n,'sex-box']}}">
                        <image class="sex-img" src="{{h}}" wx:if="{{g}}"></image>
                        <image class="sex-img" src="{{j}}" wx:if="{{i}}"></image>
                        <text class="age" wx:if="{{k}}">{{l}}</text>
                    </view>
                </view>
                <view>ID: {{o}}<image catchtap="{{q}}" class="icon-copy" src="{{p}}"></image>
                </view>
                <view class="vip-flag">
                    <view class="vip-flag-item" wx:for="{{r}}" wx:key="b">
                        <view class="vip-flag-trans">
                            <image class="title-icon" mode="widthFix" src="{{s}}"></image>
                            <view class="title-name">
                                <text>{{item.a}}</text>
                            </view>
                        </view>
                    </view>
                </view>
            </view>
        </view>
        <view bindtap="{{w}}" class="user-info flex" wx:else>
            <image class="avatar" src="{{v}}"></image>
            <view class="user-detail">
                <view class="welcome-text">点击登录</view>
            </view>
        </view>
    </view>
    <view class="mine-body">
        <view class="vip-box">
            <view class="open-vip">
                <view class="open-vip-text">
                    <image class="vip-icon" src="{{x}}"></image>
                    <view class="open-vip-title">开通会员参与互动</view>
                </view>
                <view bindtap="{{y}}" class="miss-btn">
                    <view class="miss-btn-text">开通</view>
                </view>
            </view>
        </view>
        <view class="order-fun">
            <view class="flex flex-space-between-center">
                <view class="func-title">我的订单</view>
                <view bindtap="{{A}}" class="flex-center text-gray-xs">
                    <text style="font-weight:500">全部订单</text>
                    <uni-icons bind:__l="__l" class="arrow-icon" uI="6ee0cfc0-0" uP="{{z}}" wx:if="{{z}}"></uni-icons>
                </view>
            </view>
            <view class="order-fun-list m-t-10">
                <view bindtap="{{E}}" class="order-item">
                    <image class="order-item-icon" src="{{B}}"></image>
                    <view class="order-item-text order-item-list-text">待付款</view>
                    <view class="order-count" wx:if="{{C}}">{{D}}</view>
                </view>
                <view bindtap="{{I}}" class="order-item">
                    <image class="order-item-icon" src="{{F}}"></image>
                    <view class="order-item-text order-item-list-text">待发货</view>
                    <view class="order-count" wx:if="{{G}}">{{H}}</view>
                </view>
                <view bindtap="{{M}}" class="order-item">
                    <image class="order-item-icon" src="{{J}}"></image>
                    <view class="order-item-text order-item-list-text">待收货</view>
                    <view class="order-count" wx:if="{{K}}">{{L}}</view>
                </view>
                <view bindtap="{{Q}}" class="order-item">
                    <image class="order-item-icon" src="{{N}}"></image>
                    <view class="order-item-text order-item-list-text">待评价</view>
                    <view class="order-count" wx:if="{{O}}">{{P}}</view>
                </view>
                <view bindtap="{{U}}" class="order-item">
                    <image class="order-item-icon" src="{{R}}"></image>
                    <view class="order-item-text order-item-list-text">售后</view>
                    <view class="order-count" wx:if="{{S}}">{{T}}</view>
                </view>
            </view>
        </view>
        <view class="order-fun m-t-10">
            <view class="func-title">基础功能</view>
            <view class="order-fun-list-other">
                <view bindtap="{{X}}" class="my-item">
                    <image class="order-item-icon-other" src="{{V}}"></image>
                    <view class="order-item-text">我的地址</view>
                    <image class="order-item-arrow" src="{{W}}"></image>
                </view>
                <view bindtap="{{aa}}" class="my-item">
                    <image class="order-item-icon-other" src="{{Y}}"></image>
                    <view class="order-item-text">我的收藏</view>
                    <image class="order-item-arrow" src="{{Z}}"></image>
                </view>
                <view bindtap="{{ad}}" class="my-item">
                    <image class="order-item-icon-other" src="{{ab}}"></image>
                    <view class="order-item-text">高会兑换码</view>
                    <image class="order-item-arrow" src="{{ac}}"></image>
                </view>
                <view bindtap="{{ag}}" class="my-item">
                    <image class="order-item-icon-other" src="{{ae}}"></image>
                    <view class="order-item-text">我的小葵花</view>
                    <image class="order-item-arrow" src="{{af}}"></image>
                </view>
                <view bindtap="{{aj}}" class="my-item">
                    <image class="order-item-icon-other" src="{{ah}}"></image>
                    <view class="order-item-text">消息中心</view>
                    <image class="order-item-arrow" src="{{ai}}"></image>
                </view>
                <view bindtap="{{aq}}" class="my-item">
                    <image class="order-item-icon-other" src="{{ak}}"></image>
                    <view class="set-text">设置</view>
                    <image class="icon-red" src="{{am}}" wx:if="{{al}}"></image>
                    <image class="icon-warn" src="{{ao}}" wx:elif="{{an}}"></image>
                    <view style="flex:1"></view>
                    <image class="order-item-arrow" src="{{ap}}"></image>
                </view>
                <view bindtap="{{at}}" class="my-item">
                    <image class="order-item-icon-other" src="{{ar}}"></image>
                    <view class="order-item-text">人工客服</view>
                    <image class="order-item-arrow" src="{{as}}"></image>
                </view>
            </view>
        </view>
    </view>
</view>
