.page {
    background: #f5f5f5
}

.page .main-goods {
    background-color: #f5f5f5;
    overflow: hidden
}

.page .main-goods .shop_list {
    background-color: #fff;
    border-radius: 12rpx;
    display: -webkit-flex;
    display: flex;
    height: 160rpx;
    -webkit-justify-content: flex-start;
    justify-content: flex-start;
    margin-bottom: 12rpx;
    padding: 20rpx 24rpx;
    position: relative
}

.page .main-goods .shop_list wx-image {
    height: 160rpx;
    width: 160rpx
}

.page .main-goods .shop_list .shop-name {
    display: -webkit-flex;
    display: flex;
    -webkit-flex: 1;
    flex: 1;
    -webkit-flex-direction: column;
    flex-direction: column;
    height: 100%;
    margin-left: 16rpx
}

.page .main-goods .shop_list .shop-name .name {
    color: #222;
    font-size: 26rpx;
    font-weight: 400;
    margin-bottom: 12rpx
}

.page .main-goods .shop_list .shop-name .msg {
    color: #999;
    font-size: 22rpx;
    font-weight: 400;
    margin-bottom: 34rpx
}

.page .main-goods .shop_list .shop-name .msg .left {
    margin-left: 16rpx
}

.page .main-goods .shop_list .shop-name .price {
    color: #fd6262;
    font-size: 32rpx;
    font-weight: 500
}

.page .main-goods .shop_list .cancel-box {
    -webkit-align-items: center;
    align-items: center;
    background: #ff7272;
    border-radius: 8rpx;
    color: #fff;
    display: -webkit-flex;
    display: flex;
    font-size: 28rpx;
    font-weight: 400;
    height: 200rpx;
    -webkit-justify-content: center;
    justify-content: center;
    position: absolute;
    right: -165rpx;
    top: 0rpx;
    width: 144rpx
}

.page .main-goods .shop_list .cancel-box .txt {
    width: 56rpx
}

.page .main-goods .shop_list .sold-out-container {
    background: rgba(0,0,0,.5);
    border-radius: 22rpx;
    color: #fff;
    font-family: SourceHanSansCN-Regular,SourceHanSansCN;
    font-size: 24rpx;
    font-weight: 400;
    height: 44rpx;
    left: 48rpx;
    line-height: 44rpx;
    position: absolute;
    text-align: center;
    top: 78rpx;
    width: 112rpx
}

.page .main-goods .shop_list .evaluation-btn {
    -webkit-align-items: center;
    align-items: center;
    -webkit-align-self: flex-end;
    align-self: flex-end;
    background: #fff;
    border: 2rpx solid #ddd;
    border-radius: 30rpx;
    color: #999;
    display: -webkit-flex;
    display: flex;
    font-size: 24rpx;
    font-weight: 400;
    height: 48rpx;
    -webkit-justify-content: center;
    justify-content: center;
    width: 128rpx
}
