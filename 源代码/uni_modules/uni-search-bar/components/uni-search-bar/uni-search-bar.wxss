.uni-searchbar {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row;
    padding: 10px;
    position: relative
}

.uni-searchbar__box {
    box-sizing: border-box;
    -webkit-flex: 1;
    flex: 1;
    height: 36px;
    overflow: hidden;
    padding: 5px 8px 5px 0;
    position: relative
}

.uni-searchbar__box,.uni-searchbar__box-icon-search {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row;
    -webkit-justify-content: center;
    justify-content: center
}

.uni-searchbar__box-icon-search {
    color: #b3b3b3;
    padding: 0 8px
}

.uni-searchbar__box-search-input {
    color: #333;
    -webkit-flex: 1;
    flex: 1;
    font-size: 14px
}

.uni-searchbar__box-icon-clear {
    -webkit-align-items: center;
    align-items: center;
    line-height: 24px;
    padding-left: 8px
}

.uni-searchbar__text-placeholder {
    color: #b3b3b3;
    font-size: 14px;
    margin-left: 5px
}

.uni-searchbar__cancel {
    color: #333;
    font-size: 14px;
    line-height: 36px;
    padding-left: 10px
}
