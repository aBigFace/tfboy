.select-sku-modal {
    background-color: #fff;
    border-top-left-radius: 24rpx;
    border-top-right-radius: 24rpx;
    padding-bottom: 100rpx
}

.select-sku-modal .close-icon {
    position: absolute;
    right: 30rpx;
    top: 30rpx
}

.select-sku-modal .sku-image {
    border-radius: 16rpx;
    height: 180rpx;
    width: 180rpx
}

.select-sku-modal .select-sku-info {
    -webkit-flex: 1;
    flex: 1;
    padding: 0rpx 40rpx 0 24rpx
}

.select-sku-modal .select-sku-info .sku {
    margin-bottom: 20rpx
}

.select-sku-modal .spec-name {
    font-weight: 600;
    margin-bottom: 20rpx
}

.select-sku-modal .spec-value-list {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-wrap: wrap;
    flex-wrap: wrap;
    margin: 10rpx -12rpx 20rpx
}

.select-sku-modal .spec-value-list .spec-value {
    background: #f5f5f5;
    border-radius: 28rpx;
    box-sizing: border-box;
    color: #333;
    font-size: 26rpx;
    line-height: 1.5;
    margin-bottom: 20rpx;
    margin-left: 12rpx;
    margin-right: 12rpx;
    min-width: 218rpx;
    padding: 10rpx 20rpx;
    position: relative;
    text-align: center
}

.select-sku-modal .spec-value-list .spec-value.active {
    background: #ffeaea;
    border: 1px solid #ff7272;
    color: #fd6262
}

.select-sku-modal .spec-value-list .spec-value.disabled {
    background: #fff;
    border: 1px dashed #ff7272;
    color: #999;
    opacity: .5
}

.select-sku-modal .spec-value-list .spec-value .outSale {
    background: #ff7272;
    border-radius: 8rpx 0 8rpx 0;
    color: #fff;
    font-size: 20rpx;
    line-height: 1.5;
    padding: 0 8rpx;
    position: absolute;
    right: 0;
    top: -12rpx
}

.select-sku-modal .select-count {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    padding-right: 10rpx
}

.select-sku-modal .select-count-label {
    font-weight: 600;
    margin-bottom: 20rpx
}

.select-sku-modal .modal-content {
    padding: 24rpx
}

.select-sku-modal .modal-footer > wx-button {
    border-radius: 44rpx;
    color: #fff;
    font-size: 30rpx;
    height: 88rpx;
    line-height: 88rpx;
    width: 320rpx
}

.select-sku-modal .modal-footer .joinCart {
    background: #5a5a5a!important;
    border-color: unset!important;
    color: #fff!important
}

.select-sku-modal .modal-footer .joinCart ::after {
    border-color: unset!important
}

.select-sku-modal .modal-footer .buyNow {
    background: #ff7272!important;
    border-color: unset!important;
    color: #fff!important
}

.select-sku-modal .modal-footer .buyNow ::after {
    border-color: unset!important
}

.select-sku-modal .modal-footer .w100 {
    width: 100%
}

.select-sku-modal .modal-footer .disabledBtn {
    background: #ffc6c6!important
}

.select-sku-modal .modal-footer .disabledBtnCart {
    background: #c5c5c5!important
}

.new-text-red {
    color: #ff7272;
    font-size: 22rpx;
    line-height: 1.5;
    margin-right: 40rpx
}

.hot-sell {
    left: 5px;
    position: absolute;
    top: -10px
}
