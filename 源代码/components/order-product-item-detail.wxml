        </view>
        <view class="product-spec" wx:else>
            <view class="flex-space-between-center">
                <view bindtap="{{C}}" class="spec-name flex-center" wx:if="{{x}}">
                    <text class="spec-text text-gray-xs" wx:if="{{y}}">{{z}}</text>
                    <uni-icons bind:__l="__l" class="arrow-icon" uI="cbcfb66e-2" uP="{{B}}" wx:if="{{A}}"></uni-icons>
                </view>
                <view bindtap="{{G}}" class="spec-name2 flex-center" wx:if="{{D}}">
                    <text class="spec-text text-gray-xs">下单时间：{{E}}</text>
                    <view></view>
                    <text class="spec-text text-gray-xs">支付方式：{{F}}</text>
                </view>
                <view class="product-number text-gray" wx:if="{{H}}">
                    <text class="icon">x{{I}}</text>
                </view>
            </view>
        </view>
        <view class="product-spec m-t-5" wx:if="{{J}}">
            <price bind:__l="__l" uI="cbcfb66e-3" uP="{{K}}" wx:if="{{K}}"></price>
        </view>
        <view class="error-message m-t-5" wx:if="{{L}}">{{M}}</view>
    </view>
</view>
