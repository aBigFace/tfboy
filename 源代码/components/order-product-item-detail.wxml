<view class="{{['order-product','flex',N&&'invalid-product']}}">
    <view class="left-image" wx:if="{{a}}">
        <image class="img-max" src="{{b}}"></image>
        <view class="invalid-tip" wx:if="{{c}}">已失效</view>
        <view class="img-tips" wx:if="{{d}}">{{e}}</view>
        <view class="img-tips" wx:if="{{f}}">赠品</view>
    </view>
    <view class="flex-1">
        <view class="product-info flex-space-between">
            <view class="">
                <view class="product-name max-line-two flex-1" wx:if="{{g}}">{{h}}</view>
                <view class="product-name max-line-two flex-1" wx:if="{{i}}">{{j}}　　{{k}}年</view>
            </view>
            <view class="product-price-number" wx:if="{{l}}">
                <price bind:__l="__l" uI="cbcfb66e-0" uP="{{n}}" wx:if="{{m}}"></price>
            </view>
        </view>
        <view class="product-spec" wx:if="{{o}}">
            <view class="flex-space-between-center">
                <view bindtap="{{w}}" class="spec-name flex-center" wx:if="{{p}}">
                    <text class="spec-text text-gray-xs m-r-5">数量: {{q}}</text>
                    <text class="spec-text text-gray-xs" wx:if="{{r}}">{{s}}</text>
                    <uni-icons bind:__l="__l" class="arrow-icon" uI="cbcfb66e-1" uP="{{v}}" wx:if="{{t}}"></uni-icons>
