.order-product {
    padding-bottom: 22rpx;
    padding-top: 20rpx
}

.order-product .left-image {
    border-radius: 8rpx;
    height: 128rpx;
    margin-right: 20rpx;
    position: relative;
    width: 128rpx
}

.order-product .left-image wx-image {
    border-radius: 8rpx
}

.order-product .product-name {
    color: #222;
    font-size: 28rpx;
    font-weight: 700
}

.order-product .spec-name {
    height: 32rpx;
    line-height: 32rpx;
    margin-top: 10rpx
}

.order-product .spec-name .spec-text {
    margin-right: 20rpx;
    max-width: 400rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap
}

.order-product .spec-name2 {
    display: block;
    height: 64rpx;
    line-height: 32rpx;
    margin-top: 10rpx
}

.order-product .spec-name2 .spec-text {
    margin-right: 20rpx;
    max-width: 400rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap
}

.order-product .product-price-number {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    font-size: 30rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    min-width: 100rpx;
    text-align: right
}

.order-product .product-number .icon {
    font-size: 20rpx;
    margin-right: 6rpx
}

.order-product.invalid-product {
    color: #999;
    position: relative
}

.order-product.invalid-product .invalid-tip {
    background: rgba(0,0,0,.5);
    border-radius: 0 0 4px 4px;
    bottom: 0;
    color: #fff;
    font-size: 24rpx;
    height: 32rpx;
    left: 0;
    line-height: 32rpx;
    position: absolute;
    right: 0;
    text-align: center
}

.order-product.invalid-product .error-message {
    color: #e85252;
    font-size: 24rpx
}

.order-product .img-tips {
    background: #e85252;
    border-radius: 10rpx 0rpx;
    color: #fff;
    font-size: 16rpx;
    height: 24rpx;
    left: 0;
    line-height: 24rpx;
    padding: 0 10rpx;
    position: absolute;
    top: 0
}
